# Обов'язково — отримай у @BotFather в Telegram
BOT_TOKEN=your_token_here

# База даних — вибери один варіант:

# Варіант 1: SQLite (для початку, нічого не треба встановлювати)
DATABASE_URL=sqlite+aiosqlite:///./priceguard.db

# Варіант 2: PostgreSQL (коли будеш готовий до production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/priceguard

# Необов'язково (можна залишити за замовчуванням)
FREE_TIER_MAX_ITEMS=5
PREMIUM_PRICE_UAH=99
SCHEDULER_INTERVAL_MINUTES=15
